{"files":[{"id":"ab883cb5-4774-4c0d-bebd-3eed10a7b082","name":"appsscript","type":"json","source":"{\n  \"timeZone\": \"Europe/Madrid\",\n  \"dependencies\": {},\n  \"exceptionLogging\": \"STACKDRIVER\",\n  \"runtimeVersion\": \"V8\",\n  \"webapp\": {\n    \"executeAs\": \"USER_DEPLOYING\",\n    \"access\": \"DOMAIN\"\n  }\n}"},{"id":"845499f5-07d2-4695-a3b8-1248dfb234ff","name":"Code","type":"server_js","source":"function doGet() {\n  return HtmlService.createHtmlOutputFromFile(\u0027Shoppable Banner\u0027)\n    .setTitle(\u0027Ad Preview Builder\u0027)\n    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);\n}\n\n"},{"id":"235fbcd8-8680-4c8f-bc13-ad4343e3a401","name":"Shoppable Banner","type":"html","source":"\u003c!DOCTYPE html\u003e\n\u003chtml\u003e\n\u003chead\u003e\n  \u003cscript src\u003d\"https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js\"\u003e\u003c/script\u003e\n  \n  \u003cstyle\u003e\n    body { \n      font-family: \"Figtree\", sans-serif; \n      margin: 0;\n      background: #f9f9f9; \n      display: flex;\n      flex-direction: column; \n      align-items: center; \n      justify-content: flex-start; \n      padding-top: 60px;          \n      min-height: 100vh;      \n      padding-left: 20px;\n      padding-right: 20px;\n      box-sizing: border-box;\n    }\n \n    header { text-align: center; width: 100%; max-width: 1000px; }\n \n    .main-content {\n      display: flex; \n      gap: 40px;\n      align-items: flex-start;\n      justify-content: center; \n      width: 100%;\n      max-width: 1000px; \n    }\n \n    .editor { width: 300px; }\n    .input-group { margin-bottom: 20px; }\n    label { display: block; font-family: \"Figtree\", sans-serif; font-weight: bold; color: #00A082; margin-bottom: 5px; }\n    input { width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; }\n    \n    .btn-download {\n      background: #2b2b2b; \n      color: white; \n      padding: 12px 20px; \n      border: none; \n      border-radius: 20px; \n      cursor: pointer; \n      width: 100%; \n      font-size: 16px; \n      font-family: \"Figtree\", sans-serif; \n      font-weight: bold; \n      margin-top: 10px;\n      transition: background 0.3s;\n    }\n    .btn-download:hover { background: #00A082; }\n    \n    #drop-zone {\n      border: 2px dashed #00A082;\n      border-radius: 12px;\n      padding: 15px;\n      text-align: center;\n      background: #fff;\n      cursor: pointer;\n      transition: all 0.3s ease;\n      margin-bottom: 5px;\n      font-family: \"Figtree\", sans-serif;\n      font-size: 12px;\n      color: #333;\n    }\n    #drop-zone.hover { background: #e6f6f3; border-color: #f2cc38; }\n    #drop-zone p { margin: 0; pointer-events: none; }\n \n    .preview-container { background: #F2CC38; padding: 40px; border-radius: 30px; position: relative; }\n    \n    .phone-mockup { \n      width: 284px;\n      height: 507px;\n      background: #F2CC38; \n      border-radius: 40px; \n      overflow: hidden; \n      position: relative; \n      flex-shrink: 0;\n    }\n    \n    .map-bg { width: 100%; height: 100%; object-fit: cover; position: absolute; z-index: 2; pointer-events: none; }\n    \n    .ad-text { \n      position: absolute; \n      bottom: 39px;       \n      left: 52px; \n      right: 25px;        \n      z-index: 3; \n      display: flex;\n      flex-direction: column; \n      gap: 5px;           \n      pointer-events: none;\n    }\n \n    #previewHeadline {\n      font-family: \"Figtree\", sans-serif;\n      font-weight: bold;\n      font-size: 13px;\n      color: #000000;\n      line-height: 1.2;\n      margin: 0;\n      width: 100%;\n    }\n \n    .ad-info { color: gray; font-weight: normal; font-size: 8px; font-family: \"Figtree\", sans-serif; margin: 0; }\n \n    .description-style {\n      position: absolute; \n      bottom: 0;          \n      right: 0;           \n      font-family: \"Figtree\", sans-serif;\n      text-decoration: underline;\n      font-weight: 900;\n      font-size: 12px;\n      color: #00A082;\n      margin-right: 23px;\n      z-index: 3; \n    }\n \n    .ad-image { \n        position: absolute; \n        bottom: 220px;       \n        right: 28px;        \n        width: 233px; \n        height: auto; \n        background: #eee; \n        object-fit: cover; \n        z-index: 1; \n    }\n  \n    h1 { color: #2b2b2b; font-size: 40px; font-family: \"Figtree\", sans-serif; font-weight: 700; margin-bottom: 1px; }\n\n    h2 { color: #2b2b2b; font-size: 20px; font-family: \"Figtree\", sans-serif; font-weight: 400; margin-bottom: 30px; }\n\n   .help-text { font-family: \"Figtree\", sans-serif; font-weight: 300; font-size: 10px; color: #666; margin-top: 0px; line-height: 1.4; }\n\n\n  \u003c/style\u003e\n\n   \u003clink rel\u003d\"preconnect\" href\u003d\"https://fonts.googleapis.com\"\u003e\n   \u003clink rel\u003d\"preconnect\" href\u003d\"https://fonts.gstatic.com\" crossorigin\u003e\n   \u003clink href\u003d\"https://fonts.googleapis.com/css2?family\u003dFigtree:ital,wght@0,300..900;1,300..900\u0026family\u003dNoto+Serif:ital,wght@0,100..900;1,100..900\u0026display\u003dswap\" rel\u003d\"stylesheet\"\u003e\n\n\u003c/head\u003e\n \n\u003cbody\u003e\n \n  \u003cheader\u003e\n    \u003ch1\u003eShoppable Banner Preview\u003c/h1\u003e\n    \u003ch2\u003eCreate and Download your previews\u003c/h2\u003e\n  \u003c/header\u003e\n \n  \u003cdiv class\u003d\"main-content\"\u003e\n    \u003cdiv class\u003d\"editor\"\u003e\n\n      \u003cdiv class\u003d\"input-group\"\u003e\n        \u003clabel\u003eBanner Image:\u003c/label\u003e\n        \u003cdiv id\u003d\"drop-zone\"\u003e\n          \u003cp\u003eDrag banner here or \u003cb\u003eclick to upload\u003c/b\u003e\u003c/p\u003e\n          \u003cinput type\u003d\"file\" id\u003d\"fileInput\" accept\u003d\"image/*\" style\u003d\"display:none\"\u003e\n          \u003cp class\u003d\"help-text\"\u003e Use banner size 750px x 422px.\u003c/p\u003e\n        \u003c/div\u003e\n        \n        \n      \u003c/div\u003e\n      \n      \u003cbutton id\u003d\"btnDownload\" class\u003d\"btn-download\"\u003eDownload Preview\u003c/button\u003e\n \n      \n    \u003c/div\u003e\n \n    \u003cdiv class\u003d\"preview-container\"\u003e\n      \n      \u003cdiv id\u003d\"captureArea\" class\u003d\"phone-mockup\"\u003e\n        \u003cimg class\u003d\"map-bg\" crossorigin\u003d\"anonymous\" src\u003d\"https://raw.githubusercontent.com/pb-designhub/glovo-assets/refs/heads/main/Shoppable.png\" /\u003e \n        \u003cimg id\u003d\"previewImg\" class\u003d\"ad-image\" crossorigin\u003d\"anonymous\" src\u003d\"https://via.placeholder.com/229x128?text\u003dBanner+Image\"\u003e\n      \u003c/div\u003e\n    \n    \u003c/div\u003e\n  \u003c/div\u003e\n \n  \u003cscript\u003e\n    const imageInput \u003d document.getElementById(\u0027imageInput\u0027);\n    const fileInput \u003d document.getElementById(\u0027fileInput\u0027);\n    const dropZone \u003d document.getElementById(\u0027drop-zone\u0027);\n    const previewImg \u003d document.getElementById(\u0027previewImg\u0027);\n    const btnDownload \u003d document.getElementById(\u0027btnDownload\u0027);\n \n    function updatePreview() {\n      document.getElementById(\u0027previewHeadline\u0027).innerText \u003d document.getElementById(\u0027headlineInput\u0027).value || \"Headline\";\n      document.getElementById(\u0027previewDescription\u0027).innerText \u003d document.getElementById(\u0027descriptionInput\u0027).value || \"CTA text\";\n \n      let rawValue \u003d imageInput.value.trim();\n      const prefix \u003d \"https://drive.google.com/thumbnail?authuser\u003d0\u0026sz\u003dw1000\u0026id\u003d\";\n \n      if (rawValue.includes(\"id\u003d\")) {\n        rawValue \u003d rawValue.split(\"id\u003d\")[1].split(\"\u0026\")[0];\n        imageInput.value \u003d rawValue;\n      } else if (rawValue.includes(\"/d/\")) {\n        rawValue \u003d rawValue.split(\"/d/\")[1].split(\"/\")[0];\n        imageInput.value \u003d rawValue;\n      }\n \n      if (rawValue.length \u003e 0) {\n        previewImg.crossOrigin \u003d \"anonymous\";\n        previewImg.src \u003d prefix + rawValue;\n      }\n    }\n \n    dropZone.addEventListener(\u0027click\u0027, () \u003d\u003e fileInput.click());\n    dropZone.addEventListener(\u0027dragover\u0027, (e) \u003d\u003e { e.preventDefault(); dropZone.classList.add(\u0027hover\u0027); });\n    dropZone.addEventListener(\u0027dragleave\u0027, () \u003d\u003e { dropZone.classList.remove(\u0027hover\u0027); });\n    dropZone.addEventListener(\u0027drop\u0027, (e) \u003d\u003e {\n      e.preventDefault();\n      dropZone.classList.remove(\u0027hover\u0027);\n      handleFile(e.dataTransfer.files[0]);\n    });\n    fileInput.addEventListener(\u0027change\u0027, (e) \u003d\u003e handleFile(e.target.files[0]));\n \n    function handleFile(file) {\n      if (!file || !file.type.startsWith(\u0027image/\u0027)) return;\n      const reader \u003d new FileReader();\n      reader.onload \u003d (e) \u003d\u003e {\n        previewImg.src \u003d e.target.result;\n        imageInput.value \u003d \"\";\n      };\n      reader.readAsDataURL(file);\n    }\n \n    btnDownload.addEventListener(\u0027click\u0027, function() {\n      const target \u003d document.getElementById(\u0027captureArea\u0027);\n      btnDownload.innerText \u003d \"Exporting...\";\n      btnDownload.style.opacity \u003d \"0.5\";\n\n      // Read actual rendered CSS pixel dimensions at capture time\n      const rect \u003d target.getBoundingClientRect();\n      const cssWidth \u003d Math.round(rect.width);\n      const cssHeight \u003d Math.round(rect.height);\n\n      html2canvas(target, {\n        useCORS: true,\n        allowTaint: false,\n        scale: window.devicePixelRatio || 1,\n        width: cssWidth,\n        height: cssHeight,\n        backgroundColor: null,\n        logging: false,\n        imageTimeout: 0,\n        onclone: function(clonedDoc) {\n          const clonedTarget \u003d clonedDoc.getElementById(\u0027captureArea\u0027);\n          clonedTarget.style.borderRadius \u003d \"0\";\n          clonedTarget.style.background \u003d \"transparent\";\n          // Lock cloned element to exact measured size so aspect-ratio doesn\u0027t reflow\n          clonedTarget.style.width \u003d cssWidth + \"px\";\n          clonedTarget.style.height \u003d cssHeight + \"px\";\n          clonedTarget.style.aspectRatio \u003d \"auto\";\n          clonedTarget.style.position \u003d \"relative\";\n          clonedTarget.style.left \u003d \"0\";\n          clonedTarget.style.top \u003d \"0\";\n        }\n      }).then(canvas \u003d\u003e {\n        const link \u003d document.createElement(\u0027a\u0027);\n        link.download \u003d \u0027Shoppable-Banner-Preview.png\u0027;\n        link.href \u003d canvas.toDataURL(\"image/png\", 1.0);\n        link.click();\n        btnDownload.innerText \u003d \"Download Preview\";\n        btnDownload.style.opacity \u003d \"1\";\n      }).catch(err \u003d\u003e {\n        console.error(err);\n        btnDownload.innerText \u003d \"Download Preview\";\n        btnDownload.style.opacity \u003d \"1\";\n      });\n    });\n \n    window.onload \u003d updatePreview;\n  \u003c/script\u003e\n\u003c/body\u003e\n\u003c/html\u003e"}]}